<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remote Access Request"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="The peer wants to access your device. Select what to allow:"
        android:textColor="#333333"
        android:layout_marginBottom="16dp" />

    <CheckBox
        android:id="@+id/cbScreenView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View my screen (read-only)"
        android:textColor="@color/black"/>

    <CheckBox
        android:id="@+id/cbScreenControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Control my screen (touch)"
        android:textColor="@color/black"/>

    <CheckBox
        android:id="@+id/cbFileBrowse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Browse my files"
        android:textColor="@color/black"/>

    <CheckBox
        android:id="@+id/cbCameraGallery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Access my camera/gallery"
        android:textColor="@color/black"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnDeny"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deny"
            style="?android:attr/buttonBarButtonStyle"
            android:textColor="@color/purple_500"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnAllow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Allow Selected"
            style="?android:attr/buttonBarButtonStyle"
            android:textColor="@color/purple_500"/>
    </LinearLayout>

</LinearLayout>
